# EditorConfig — Code Style Consistency
# https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# YAML files (GitHub Actions workflows, config files)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 120

# Shell scripts
[*.sh]
indent_size = 2
shell_variant = bash

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# JSON files
[*.json]
indent_size = 2

# Makefile (must use tabs)
[Makefile]
indent_style = tab
